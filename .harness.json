{
  "worker_policy": {
    "worker_env": ["GH_TOKEN", "CLAUDE_CODE_OAUTH_TOKEN"],
    "network_allowlist": ["chatgpt.com", "api.openai.com", "api.anthropic.com", "github.com", "registry.npmjs.org"],
    "capabilities": []
  },
  "director": {
    "worker_runtime": "claude",
    "worker_runtimes": {
      "claude": "node {harness_root}/worker-runtime/app-server/dist/bin.js app-server"
    },
    "worker_runtime_sandbox": {
      "claude": "danger-full-access"
    },
    "worker_runtime_read_timeout": {
      "claude": 600
    },
    "worker": {
      "tools": "linear",
      "install_skills": true
    },
    "states": {
      "merging": "In Review"
    }
  }
}
